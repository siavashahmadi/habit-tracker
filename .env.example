# Supabase credentials (required — baked into the JS bundle at build time)
# Get these from your Supabase project's Connect modal or Settings → API → Publishable Key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Host port for Docker (optional, defaults to 3000)
PORT=3000
